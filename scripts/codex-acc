#!/usr/bin/env bash
# codex-acc — switch between Codex CLI accounts instantly by swapping
# ~/.codex/auth.json, with no logout/login round-trip. Recommended alias: cx
#
#   codex-acc            jump to the NEXT account (with 2 accounts = instant toggle)
#   codex-acc <name>     jump straight to <name>
#   codex-acc pick       fuzzy-pick with fzf (nice when you have many)
#   codex-acc ls         list saved accounts (marks the active one)
#   codex-acc save <n>   remember the currently logged-in account as <n>
#   codex-acc rm <n>     forget it
#
# Accounts are snapshots of auth.json stored in $CODEX_HOME/accounts (0600).
# Switching only rewrites auth.json — config, skills, history and sessions are shared.

dir="${CODEX_HOME:-$HOME/.codex}"
auth="$dir/auth.json"
store="$dir/accounts"
mkdir -p "$store"; chmod 700 "$store"

fp() { [ -f "$1" ] && sha256sum "$1" 2>/dev/null | cut -d' ' -f1; }
do_switch() {
  [ -f "$store/$1.json" ] || { echo "no account '$1' — run: codex-acc save $1"; return 1; }
  # atomic swap: write a sibling temp then rename, so a crash can't truncate auth.json
  local tmp="$auth.tmp.$$"
  cp "$store/$1.json" "$tmp" && chmod 600 "$tmp" && mv -f "$tmp" "$auth" || { rm -f "$tmp"; echo "switch failed"; return 1; }
  echo "✓ now using: $1"
}

# management subcommands (act on a named account, then exit)
case "${1:-}" in
  save) [ -n "${2:-}" ] || { echo "usage: codex-acc save <name>"; exit 1; }
        [ -f "$auth" ] || { echo "not logged in — run 'codex login' first"; exit 1; }
        tmp="$store/$2.json.tmp.$$"
        cp "$auth" "$tmp" && chmod 600 "$tmp" && mv -f "$tmp" "$store/$2.json" || { rm -f "$tmp"; echo "save failed"; exit 1; }
        echo "✓ saved current login as: $2"; exit 0 ;;
  rm)   [ -n "${2:-}" ] || { echo "usage: codex-acc rm <name>"; exit 1; }
        rm -f "$store/$2.json" && echo "✓ removed: $2"; exit 0 ;;
esac

# gather saved accounts + record which one is active (1-based position, 0 = none)
names=(); cur="$(fp "$auth")"; active_idx=0; i=0
for f in "$store"/*.json; do
  [ -e "$f" ] || continue
  n="$(basename "$f" .json)"; [ "$n" = ".prev" ] && continue
  names+=("$n"); i=$((i+1))
  [ "$(fp "$f")" = "$cur" ] && active_idx=$i
done
count=${#names[@]}
if [ "$count" -eq 0 ]; then
  echo "No saved accounts yet."
  echo "While logged in, run:  codex-acc save <name>"
  exit 0
fi

case "${1:-}" in
  ls|list)
    i=1
    for n in "${names[@]}"; do
      [ "$i" -eq "$active_idx" ] && echo "* $n" || echo "  $n"
      i=$((i+1))
    done ;;
  pick)
    command -v fzf >/dev/null 2>&1 || { echo "fzf not installed"; exit 1; }
    sel="$(printf '%s\n' "${names[@]}" | fzf --height=40% --reverse --prompt='codex account> ')"
    [ -n "$sel" ] && do_switch "$sel" ;;
  "")  # bare invocation → rotate to the next account (wraps around)
    if [ "$count" -eq 1 ]; then echo "only one account: ${names[0]}"; exit 0; fi
    do_switch "${names[$(( active_idx % count ))]}" ;;   # active_idx is 1-based → 0-based next
  *)   # direct: codex-acc <name>
    do_switch "$1" ;;
esac
