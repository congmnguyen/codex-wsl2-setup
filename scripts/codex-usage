#!/usr/bin/env python3
"""Show Codex usage-limit remaining + reset times from local rollout logs (no browser)."""
import glob, os, time, json, datetime

files = glob.glob(os.path.expanduser('~/.codex/sessions/**/*.jsonl'), recursive=True)
files.sort(key=os.path.getmtime, reverse=True)

def find_rl(o):
    if isinstance(o, dict):
        if isinstance(o.get('rate_limits'), dict):
            return o['rate_limits']
        for v in o.values():
            r = find_rl(v)
            if r: return r
    elif isinstance(o, list):
        for v in o:
            r = find_rl(v)
            if r: return r
    return None

rl = None; src_mtime = None
for f in files[:40]:
    got = None
    try:
        with open(f) as fh:
            for line in fh:
                if '"rate_limits"' in line:
                    r = find_rl(json.loads(line))
                    if r: got = r
    except Exception:
        continue
    if got:
        rl = got; src_mtime = os.path.getmtime(f); break

if not rl:
    print("No rate-limit data found in ~/.codex/sessions (run codex at least once).")
    raise SystemExit(1)

now = time.time()
age = int(now - src_mtime)
age_str = f"{age // 3600}h{age % 3600 // 60:02d}m" if age >= 3600 else f"{age // 60}m ago"
print(f"Codex usage (updated {age_str})")

WIDTH = 20
today = datetime.date.today()
for key, label in (('primary', '5h limit:'), ('secondary', 'Weekly limit:')):
    d = rl.get(key)
    if not d:
        continue
    ra = d.get('resets_at')
    left = max(0.0, 100.0 - d.get('used_percent', 0))
    fill = round(left / 100 * WIDTH)
    bar = '█' * fill + '░' * (WIDTH - fill)
    dt = datetime.datetime.fromtimestamp(ra)
    when = dt.strftime('%H:%M') if dt.date() == today else dt.strftime('%H:%M on %-d %b')
    print(f"  {label:<14}[{bar}] {left:.0f}% left (resets {when})")
